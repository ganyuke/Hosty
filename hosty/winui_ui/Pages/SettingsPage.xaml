<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="winui_ui.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="24" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <InfoBar
                x:Name="ErrorBar"
                IsOpen="False"
                Severity="Error"
                Title="Settings could not be saved" />

            <StackPanel Spacing="12">
                <TextBlock Text="App" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Grid Padding="16" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Theme" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Use the system setting or choose a fixed appearance." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox x:Name="ThemeBox" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="ThemeBox_SelectionChanged">
                                <ComboBoxItem Content="Use system setting" Tag="system" />
                                <ComboBoxItem Content="Light" Tag="light" />
                                <ComboBoxItem Content="Dark" Tag="dark" />
                            </ComboBox>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Run in background on close" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Keep Hosty alive when you close the window." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="BackgroundToggle" Grid.Column="1" Toggled="PreferenceToggle_Toggled" OnContent="" OffContent="" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="Servers" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Grid Padding="16" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Create backup when a server stops" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Automatically save a world backup after shutdown." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoBackupToggle" Grid.Column="1" Toggled="PreferenceToggle_Toggled" OnContent="" OffContent="" />
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Default RAM" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="DefaultRamText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <NumberBox
                                x:Name="DefaultRamBox"
                                Grid.Column="1"
                                Minimum="512"
                                Maximum="65536"
                                SmallChange="256"
                                LargeChange="1024"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="DefaultRamBox_ValueChanged" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
