<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="winui_ui.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" MaxWidth="680" HorizontalAlignment="Left" Spacing="20">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Image Width="48" Height="48">
                    <Image.Source>
                        <SvgImageSource UriSource="ms-appx:///Assets/AppIcon.svg" />
                    </Image.Source>
                </Image>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hosty" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Fabric Minecraft server manager" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Grid Padding="16" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Version" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="VersionText" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid Padding="16" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Website" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <HyperlinkButton Grid.Column="1" Content="GitHub" NavigateUri="https://github.com/sugarycandybar/Hosty" Padding="0" />
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid Padding="16" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="License" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="GPL-3.0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
