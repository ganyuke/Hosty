#!/usr/bin/env @PYTHON@
import os
import signal
import sys
from pathlib import Path

# Set up data directory as the old wrapper did
xdg_data_home = os.environ.get("XDG_DATA_HOME")
if not xdg_data_home:
    xdg_data_home = os.path.join(os.path.expanduser("~"), ".local", "share")

hosty_data_dir = os.environ.get("HOSTY_DATA_DIR")
if not hosty_data_dir:
    hosty_data_dir = os.path.join(xdg_data_home, "hosty")

os.environ["HOSTY_DATA_DIR"] = hosty_data_dir

# Create the data dir if it does not exist
try:
    os.makedirs(hosty_data_dir, exist_ok=True)
except Exception as e:
    print(f"Warning: Could not create data directory {hosty_data_dir}: {e}", file=sys.stderr)

# Set up the path to find the hosty package
pkgdatadir = '@pkgdatadir@'
if os.path.exists(pkgdatadir):
    sys.path.insert(0, pkgdatadir)

from hosty.entry import main


if __name__ == "__main__":
    # Handle SIGINT (Ctrl+C) gracefully
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    sys.exit(main())
